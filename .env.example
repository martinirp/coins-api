# Port where the Tibia Coins API will listen (default is 5001 to avoid conflicts)
PORT=5001

# Tibia.com account credentials
TIBIA_EMAIL=your_email@domain.com
TIBIA_PASSWORD="your_password_here"

# Tibia Authenticator 2FA secret key (in Base32, e.g., JBSWY3DPEHPK3PXP)
TIBIA_TOTP_KEY=your_totp_secret_here

# Background polling interval in seconds to pre-populate transaction history
# Set to 0 to disable background polling and check only on-demand
POLL_INTERVAL_SECONDS=60

# Optional: Override python executable path (default: python on Windows, python3 on Linux)
# PYTHON_CMD=python3
